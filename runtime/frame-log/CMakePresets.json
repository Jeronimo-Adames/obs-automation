{
  "version": 8,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 28,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "windows-x64",
      "displayName": "Windows x64",
      "description": "Build Frame Log for 64-bit OBS on Windows",
      "binaryDir": "${sourceDir}/build_x64",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "generator": "Visual Studio 17 2022",
      "architecture": "x64,version=10.0.22621",
      "warnings": {
        "dev": true,
        "deprecated": true
      },
      "cacheVariables": {
        "ENABLE_FRONTEND_API": true,
        "ENABLE_QT": false,
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/out/stage"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-x64",
      "configurePreset": "windows-x64",
      "displayName": "Windows x64",
      "description": "Build Frame Log for 64-bit OBS on Windows",
      "configuration": "RelWithDebInfo"
    }
  ]
}
